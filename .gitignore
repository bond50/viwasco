.npmrc
.yarnrc*
.pnpmrc

# --- Certs / keys ---
*.pem
*.key
*.crt
*.pfx

# --- Misc you had ---
.scripts.zip
.vercel
lib/generated/prisma

# --- Docker (the file itself should be a separate .dockerignore) ---
.dockerignore
.playwright-mcp/
.env.local
/prisma/src/generated/prisma
generated/
extra/
**/extra/

secrets/
**/secrets/
